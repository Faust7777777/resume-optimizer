# AI 服务配置
# 支持的提供商: openai, anthropic, baidu, alibaba, mock
NEXT_PUBLIC_AI_PROVIDER=mock

# OpenAI 配置 (provider=openai 时使用)
OPENAI_API_KEY=sk-your-openai-api-key
NEXT_PUBLIC_AI_MODEL=gpt-4

# Anthropic (Claude) 配置 (provider=anthropic 时使用)
ANTHROPIC_API_KEY=sk-ant-your-api-key
NEXT_PUBLIC_AI_MODEL=claude-3-sonnet-20240229

# 百度文心一言配置 (provider=baidu 时使用)
BAIDU_API_KEY=your-baidu-api-key
BAIDU_SECRET_KEY=your-baidu-secret-key

# 阿里巴巴通义千问配置 (provider=alibaba 时使用)
ALIBABA_API_KEY=your-alibaba-api-key

# 自定义API地址（可选，用于代理或第三方API）
NEXT_PUBLIC_AI_BASE_URL=https://api.openai.com/v1

# 开发环境使用 mock 数据，生产环境配置真实API Key
