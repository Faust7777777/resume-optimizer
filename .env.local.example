# ============================================================
# Coze workflow / chat
# COZE_API_TOKEN=your-coze-token-here
# COZE_API_BASE_URL=https://api.coze.cn
# COZE_CHAT_DEFAULT_BOT_ID=your-default-chat-bot-id
#
# ============================================================
# AI 大模型接入配置
# 将本文件复制为 .env.local 并填入你的真实API密钥
# ============================================================

# 选择 AI 提供商 (必填)
# 可选值: openai, anthropic, alibaba, baidu, deepseek, zhipu, kimi
AI_PROVIDER=kimi

# ============================================================
# OpenAI / GPT 配置
# 官网: https://platform.openai.com
# ============================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=https://api.openai.com/v1  # 可选，使用代理时修改

# ============================================================
# Anthropic / Claude 配置
# 官网: https://console.anthropic.com
# ============================================================
# ANTHROPIC_API_KEY=sk-ant-your-api-key-here
# ANTHROPIC_MODEL=claude-3-sonnet-20240229
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# ============================================================
# 阿里通义千问配置
# 官网: https://dashscope.aliyun.com
# ============================================================
# ALIBABA_API_KEY=sk-your-dashscope-key-here
# ALIBABA_MODEL=qwen-max

# ============================================================
# 百度文心一言配置
# 官网: https://console.bce.baidu.com/qianfan
# ============================================================
# BAIDU_API_KEY=your-baidu-api-key
# BAIDU_SECRET_KEY=your-baidu-secret-key
# BAIDU_MODEL=ernie-bot-4

# ============================================================
# DeepSeek 配置
# 官网: https://platform.deepseek.com
# ============================================================
# DEEPSEEK_API_KEY=sk-your-deepseek-key-here
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ============================================================
# 智谱 AI (GLM-4) 配置
# 官网: https://open.bigmodel.cn
# ============================================================
# ZHIPU_API_KEY=your-zhipu-api-key
# ZHIPU_MODEL=glm-4

# ============================================================
# Kimi (Moonshot) 配置
# 官网: https://platform.moonshot.cn
# ============================================================
KIMI_API_KEY=sk-your-kimi-key-here
KIMI_MODEL=moonshot-v1-8k
KIMI_BASE_URL=https://api.kimi.com/coding

# ============================================================
# 提示:
# 1. 只需配置你选择的 AI_PROVIDER 对应的 API Key
# 2. 其他不需要的提供商配置可以注释掉或删除
# 3. 重启开发服务器后配置生效
# ============================================================
